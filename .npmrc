# Install dependencies from the registry, never as symlinks to sibling
# directories. Without this, running `npm install` in a checkout that sits
# next to a local ../crypto directory resolves @shieldfive/crypto to that
# symlink and writes a "link": true entry into package-lock.json, which then
# fails `npm ci` anywhere the sibling isn't present (CI, a fresh clone).
install-links=true
